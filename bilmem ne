		HookContainer = function(container, noScroll, seperation, startY)
			local container = {main = container}
			container.drawX, container.drawY = 0, startY or (seperation or 12) / 2
			container.drawHeight, container.seperation = 0, (seperation or 12)
			container.noScroll = noScroll
			return container
		end;
		DrawButton = function(container, size, text, fn, ySize, parent, noWait)
			if (not noWait) and (not TK.FastLoad) then wait() end
			local xposOffset, xposScale = 0, container.drawX
			if xposScale == 2/3 then -- Spacing errors (should use an epsilon)
				xposScale = 0.666
				container.drawX = 0.666
			end
			local xszOffset, xszScale = 0, size
			if container.drawX ~= 0 then
				xszOffset = -5
				if size + container.drawX > 0.998 then
					xszOffset = -10
				end
			elseif size == 1 then
				local bzz = 4
				if container.noScroll then
					bzz = 0
				end
				xszOffset = -(container.seperation) - bzz
				xposOffset = container.seperation / 2
			else
				xszOffset = -4 + -(container.seperation / 2)
				xposOffset = container.seperation / 2
			end
			ySize = ySize or 20
			local obj = TK.Util.Object("TextButton", {
				Parent = parent or container.main;
				BackgroundColor3 = TK.Settings.Primary(),
				BorderSizePixel = 0;
				Position = UDim2.new(xposScale, xposOffset, 0, container.drawY);
				Size = UDim2.new(xszScale, xszOffset, 0, ySize);
				Font = 'SourceSans';
				FontSize = 'Size14';
				Text = text;
				TextSize = 14;
				TextColor3 = TK.Settings.Text();
				ZIndex = 15;
			})
			TK.Util.Object("TextLabel", {
				Parent = obj;
				BackgroundColor3 = TK.Util.Shift(TK.Util.Shift(TK.Settings.Primary(), -100), 10);
				BorderSizePixel = 0;
				Name = "Shadow";
				ZIndex = 14;
				Position = UDim2.new(0, 1, 0, 1);
				Size = UDim2.new(1, 0, 1, 0);
				Text = '';
			})
			table.insert(self.primaryPool, obj)
			self.text2Func[text] = fn
			obj.MouseButton1Down:connect(function()
				spawn(fn)
			end)
			obj.MouseButton2Down:connect(function()
				if obj:FindFirstChild("KBLabel") then
					obj.KBLabel:Destroy()
					for _, kblist in pairs(TK.Util.Keybinds) do
						for i, kb in pairs(kblist) do
							if kb[1] == text then
								table.remove(kblist, i)
							end
						end
					end
					self.text2Keybind[text] = nil
				end
				local lab = Instance.new("TextLabel", obj)
				lab.Name = "KBLabel"
				lab.Position = UDim2.new(1, -20, 0, 0)
				lab.Size = UDim2.new(0, 15, 1, 0)
				lab.Font = 'SourceSans'
				lab.TextSize = 14
				lab.TextYAlignment = Enum.TextYAlignment.Center
				lab.ZIndex = 15
				lab.BorderSizePixel = 0
				lab.BackgroundTransparency = 1
				lab.TextColor3 = TK.Util.Shift(TK.Settings.Text(), -60)
				lab.Text = '?'
				local btn = TK.Util.GetNextButton()
				if btn == Enum.KeyCode.Space then
					lab:Destroy()
					return
				end
				if TK.Util.Keybinds[btn] then
					TK.Util.Keybinds[btn] = table.insert(TK.Util.Keybinds[btn], {text, function() spawn(fn) end})
