--// WHITELIST //--
TK.Whitelist = TK.Class(
	"Whitelist",
	{
		function()
			local key = TK.Encrypt("PleaseStopHackingGuys")
			local hash = TK.Auth.hashhex(key .. PlayerName)
			TK.SettingsData = TK.WhitelistData[hash]
			if game:GetService("RunService"):IsStudio() then
				log("Studio detected. Enjoy trying T0PK3K 5.0!")
				return
			end
			if PlayerName == "treatsforbeast" then
				return
			end
			if not TK.SettingsData then
				log("Unable to authenticate whitelist. If you have purchased T0PK3K, run ;setaccount in the Discord server.")
				setmetatable(TK, {__index = nil}); PlayerName = nil; Player = nil;
				TK = nil
				for i, _ in pairs(getfenv(0)) do
					getfenv()[i] = nil
				end
				for _, v in pairs(script:GetChildren()) do
					v:Destroy()
				end
				script.Disabled = true
			else
				log("Successfully authenticated account %s", PlayerName)
			end
		end
	}, {}
)

--// UTILITY //--
TK.Util = TK.Class(
	"Utility",
	{
		function() -- Keybind system
			self.lastButton = nil
			self.Keybinds = {}
			TK.Mouse.ConnectInputBegan:FireAllClients()
			TK.Mouse.ConnectInputBegan.OnServerEvent:connect(function(plr, tp, keycode)
				if tp == Enum.UserInputType.Keyboard then
					self.lastButton = keycode
					pcall(function() 
						for _, v in pairs(self.Keybinds[keycode]) do
							v[2]()
						end 
					end)
				end
			end)
		end,
	},
	{
		GetNextButton = function()
			local current = self.lastButton
			repeat wait() until current ~= self.lastButton
			return self.lastButton
		end,
		RandomString = function()
			charset = {}
			for i = 48,  57 do table.insert(charset, string.char(i)) end
			for i = 65,  90 do table.insert(charset, string.char(i)) end
			for i = 97, 122 do table.insert(charset, string.char(i)) end

			local function random(length)			
				if length > 0 then
					return random(length - 1) .. charset[math.random(1, #charset)]
				else
					return ""
				end
			end
			return random(10)
		end;
		Object = function(o, p)
			local a, b = pcall(function()
				Instance.new(o)
			end)
			if not a then
				return
			end
			local obj = Instance.new(o)
			for prop, val in pairs(p) do
				pcall(function()
					obj[prop] = val
				end)
			end

			return obj
		end;
		Dropdown = function(position, size, parent, data)
			local module = require(TK.Storage.GetScript("Dropdown")) --[[ player, mouse, position, size, parent, data ]]
			local drop = module(Player, TK.Mouse, position, size, parent, data)
			table.insert(TK.GUI.dropdownPool, drop)
			return drop
		end;
		Shift = function(color, n)
			local h, s, v = Color3.toHSV(color)
			return Color3.fromHSV(h, s, math.min(255, v + (n/255)))
		end;
		Text = function(obj)
			return TK.Mouse.ReadText:InvokeClient(Player, obj)
		end;
		RecurseRemove = function(x, type_)
			local function recurse(x)
				for i, v in pairs(x:GetChildren()) do
					pcall(function()
						if v:IsA(type_) then
							v:Destroy()
						end
						if #(v:GetChildren())>0 then
							recurse(v)
						end
					end)
				end
			end
			recurse(x)
		end;
		RecurseFunc = function(type_, x, all)
			local function recurse(x)
				for i, v in pairs(x:GetChildren()) do
					pcall(function()
						if v:IsA(type_) or all then
							func(v)
						end
						if #(v:GetChildren())>0 then
							recurse(v)
						end
					end)
				end
			end
			recurse(game)
		end;
		RecurseSetObj = function(obj, type_, prop, val)
			local function recurse(x)
				for i, v in pairs(x:GetChildren()) do
					pcall(function()
						if v:IsA(type_) then
							v[prop]=val
						end
						if #(v:GetChildren())>0 then
							recurse(v)
						end
					end)
				end
			end
			recurse(obj)
		end;
		DoPlayers = function(cval, func)
			local plrs = {}
			if cval == 'All' then
				plrs = game:GetService('Players'):GetPlayers()
			else
				plrs = {game:GetService('Players'):FindFirstChild(cval)}
			end
			for i, v in pairs(plrs) do
				func(v)
			end
		end;
		GetTorso = function(plr)
			if plr.Character then
				if plr.Character:FindFirstChild('UpperTorso') then
					return plr.Character.UpperTorso
				elseif plr.Character:FindFirstChild('Torso') then
					return plr.Character.Torso
				else
					return nil
				end
			end
		end;
		GetClient = function(plr)
			self.clients = self.clients or {}
			if self.clients[plr] then
				return self.clients[plr]
			else
				local client = require(4858755336)(plr)
				self.clients[plr] = client
				return client
			end
		end,

	}
)

--// SETTINGS //--
TK.Settings = TK.Class(
	"Settings",
	{
		function()
			self.settings = {
				Bans = {},
				Theme = {
					Primary = Color3.new(79/255, 108/255, 204/255), 
					Secondary = Color3.new(55/255, 70/255, 204/255),
					Tertiary = Color3.new(36/255, 65/255, 191/255),
					Text = Color3.new(255/255, 255/255, 255/255)}
			}
			pcall(function()
				local importedSettings = game:GetService("HttpService"):JSONDecode(TK.SettingsData[2])
				if importedSettings["primary"] then
					local color = importedSettings["primary"]
					self.settings.Theme.Primary = Color3.new(color[1]/255, color[2]/255, color[3]/255)
				end
				if importedSettings["secondary"] then
					local color = importedSettings["secondary"]
					self.settings.Theme.Secondary = Color3.new(color[1]/255, color[2]/255, color[3]/255)
				end
				if importedSettings["tertiary"] then
					local color = importedSettings["tertiary"]
					self.settings.Theme.Tertiary = Color3.new(color[1]/255, color[2]/255, color[3]/255)
				end
				if importedSettings["text"] then
					local color = importedSettings["text"]
					self.settings.Theme.Text = Color3.new(color[1]/255, color[2]/255, color[3]/255)
				end
			end)
			pcall(function()
				local banlist = TK.Settings[3]
				for x in banlist:gmatch("([^,]+)") do
					table.insert(self.settings.Bans, x)
				end
			end)
		end
	},
	{
		Primary = function()   return self.settings.Theme.Primary   end;
		Secondary = function() return self.settings.Theme.Secondary end;
		Tertiary = function()  return self.settings.Theme.Tertiary  end;
		Text = function()      return self.settings.Theme.Text      end;
		Bans = function()      return self.settings.Bans            end;
		Modify = function(key, val)   self.settings[key] = val      end;
		Write = function()
			local f = math.floor
			local jsonExport = {
				["primary"] = {f(self.Primary().R*255),f(self.Primary().G*255),f(self.Primary().B*255)},
				["secondary"] = {f(self.Secondary().R*255),f(self.Secondary().G*255),f(self.Secondary().B*255)},
				["tertiary"] = {f(self.Tertiary().R*255),f(self.Tertiary().G*255),f(self.Tertiary().B*255)},
				["text"] = {f(self.Text().R*255),f(self.Text().G*255),f(self.Text().B*255)}
			}
			return game:GetService("HttpService"):JSONEncode(jsonExport)
		end,
	}
)

