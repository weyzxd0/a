TK.ScriptTab = TK.Class(
	"Scripts",
	{
		function()
			local hook = TK.GUI.HookContainer(TK.GUI.GetContainer('Scripts').Container)
			local search = Button(1, '', function() end)(hook)
			drop = TK.Util.Dropdown(UDim2.new(0, 0, 0, 0), UDim2.new(1, 0, 1, 0), search, {'All'})
			function fixPlayerDrop()
				local t = {'All'}
				for i, v in pairs(game.Players:GetPlayers()) do
					table.insert(t, v.Name)
				end
				drop.SetTable(t)
			end
			game.Players.PlayerAdded:connect(function()
				fixPlayerDrop()
			end)
			game.Players.PlayerRemoving:connect(function()
				fixPlayerDrop()
			end)
			fixPlayerDrop()
			self.cval = 'All'
			drop.Changed(function(cval) self.cval = cval end)
			drop.Select(PlayerName)
			local search = TextBox(1, '')(hook)
			local origy = hook.drawY
			Spacing()(hook)
			Spacing()(hook)
			local scripts = script.Scripts
			local container = {}
			function Run(scr, target)
				TK.Log.Record("Ran Script", scr.Name)
				local runner = TK.Storage.GetScript("Runner"):Clone()
				local req = scr:Clone()
				req.Name = "Require"
				req.Parent = runner
				local tgv = Instance.new("StringValue", runner)
				tgv.Value = target
				tgv.Name = "Target"
				runner.Parent = game.ServerScriptService
				runner.Disabled = false
			end
			function MakeList(condition)
				for i,v in pairs(hook.main:GetChildren()) do
					if v.Name == "Script" then
						v:Destroy()
					end
				end
				hook.drawY = origy
				local children = scripts:GetChildren()
				table.sort(children, function ( a, b )
					return a.Name:lower() < b.Name:lower()
				end)
				for i, v in pairs(children) do
					if string.find(v.Name:lower(), condition:lower()) or (condition == "") or (condition == " ") then
						local scr = Button(1, v.Name, function()
							spawn(function() 
								if self.cval == 'All' then
									for _, plr in pairs(game.Players:GetPlayers()) do
										Run(v, plr.Name)
									end	
								else
									Run(v, self.cval)
								end
							end)
						end, 25, nil, true)(hook)
						scr.Name = 'Script'
					end
				end
			end
			TK.Mouse.ConnectInputRead:FireAllClients(search)
			TK.Mouse.ConnectInputRead.OnServerEvent:connect(function(plr, obj)
				if obj == search then
					MakeList(TK.Util.Text(search))
				end
			end)
			MakeList('')
		end,
	},
	{}
)

