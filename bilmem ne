			for x, m in pairs(self.Whitelist) do
				if m == p then
					warn(m .. " unwhitelisted")
					table.remove(self.Whitelist, x)
					if game:GetService('Players'):FindFirstChild(p) then
						game:GetService('Players')[p]:Kick("You are kicked.")
					end
				end
			end
		end;
		Whitelisted = function(p)
			for x, m in pairs(self.Whitelist) do
				if m == p.Name then
					return true
				end
			end
			return false
		end;
		Banned = function(p)
			for x, m in pairs(self.Bans) do
				if m == p.Name then
					return true
				end
			end
			return false
		end;
		Ban = function(p)
			table.insert(self.Bans, p.Name)
			p:Kick("You are banned.")
		end,
	}
)

