TK.LogsTab = TK.Class(
	"Logs",
	{
		function()
			local hook = TK.GUI.HookContainer(TK.GUI.GetContainer('Logs').Container)
			self.scroll = ScrollingContainer(340)(hook)
			TK.Util.Object("UIListLayout", {
				Parent = self.scroll.main;
				SortOrder = Enum.SortOrder.LayoutOrder;
			})
			TK.Log.Event.Event:Connect(function(log)
				self.AddLog(#_G.Logs, log)
			end)
			for n, data in pairs(_G.Logs) do
				self.AddLog(n, log)
			end
		end,
	},
	{
		AddLog = function(n, data)
			-- [[ os.time(), PlayerName, Player.UserId, action, value or "", extra or "" ]]
			local date = os.date("*t", data[1])
			local date = ("%02d:%02d %s"):format(
			((date.hour % 24) - 1) % 12 + 1, date.min, date.hour > 11 and "PM" or "AM")
			local log = Text(1, data[2] .. " " .. data[4] .. (data[5] ~= "" and " on " .. data[5] or "") .. " " .. date)(self.scroll)
			log.TextXAlignment = Enum.TextXAlignment.Right
			log.LayoutOrder = -n
			TK.GUI.AddLeftIcon(log, "https://www.roblox.com/headshot-thumbnail/image?userId="..tostring(data[3]).."&width=48&height=48&format=png", 20)
		end,
	}
)

