TK.Log = TK.Class(
	"Log",
	{
		function()
			self.Event = game:GetService("ServerScriptService"):FindFirstChild("Log")
			if not self.Event then
				self.Event = Instance.new("BindableEvent", game:GetService("ServerScriptService"))
				self.Event.Name = "Log"
			end
		end,
	},
	{
		Record = function(action, value, extra)
			local log = {os.time(), PlayerName, Player.UserId, action, value or "", extra or ""}
