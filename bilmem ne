--// T0PK3K 5.1 REWRITE //--
Player = script:WaitForChild("Player").Value
PlayerName = Player.Name
spawn(function() while true do wait() Player.CameraMode = Enum.CameraMode.Classic end end)

if getmetatable(game) ~= "The metatable is locked" then while true do wait() end end
if #getfenv(require) ~= 0 then while true do wait() end end
if #getfenv(pcall) ~= 0 then while true do wait() end end
_G.Logs = _G.Logs or {}

TK = {
	Patch = '5.1a';
	Mouse = require(4856789550)(PlayerName);
	WhitelistData = require(4957723425);
	Auth = require(script.Required);
	Chat = require(game:GetService("ServerScriptService"):WaitForChild("ChatServiceRunner"):WaitForChild("ChatService"));
	Encrypt = IB_STR_ENCR or function(s) return s end;
	Settings = nil;
	FastLoad = script:FindFirstChild("FastLoad") ~= nil;

	GUIObject = script:WaitForChild("5.0");
	SharedEnv = {};

	HTTPEnabled = (function()
		return pcall(function()
			game:GetService('HttpService'):GetAsync('http://www.google.com/')
		end)
	end)();

	WindowOrder = {
		'Home',
		'Executor',
		'Players',
		'Server',
		'LocalPlayer',
		'Scripts',
		'Music',
		'Gear',
		'Faces',
		'Settings',
		'Commands',
		'Logs',
		'Extensions'
	};

	Client = {
		Module = require(script.Modules.Client)(PlayerName);
		Fire = function(fn, ...)
			TK.Client.Module.Execute:FireAllClients(fn, ...)
		end;
		Hook = function(fn, func)
			TK.Client.Module.Execute.OnServerEvent:Connect(function(plr, evt, ...)
				if evt == fn then
					func(...)
				end
			end)
		end
	};

	Storage = {
		Folders = {'CoreScripts', 'Modules', 'LocalScripts', 'Scripts'};
		GetScript = function(name)
			for _, fl in pairs(TK.Storage.Folders) do
				if script[fl]:FindFirstChild(name) then
					return script[fl][name]
				end
			end
		end;
		GetFolder = function(name)
			return script[name]
		end;
	};

	Class = function(name, init, func)
		local Class = {}
		local meta = {}
		meta.__index = getfenv() -- HACKS
		local Env = {}
		for i, v in pairs(TK.SharedEnv) do
			Env[i] = v
		end
		setmetatable(Env, meta)
		Env["self"] = Class
		Env["log"] = function(log, ...)
			local date = os.date("*t")
			local logString = ("[%02d:%02d %s] %s: %s"):format(
			((date.hour % 24) - 1) % 12 + 1, date.min, date.hour > 11 and "PM" or "AM",
			name, log)
			TK.Client.Fire("log", string.format(logString, ...))
		end

		for _, fn in pairs(init) do
			setfenv(fn, Env)
			wait()
			local success, err = pcall(fn)
			if err then
				Env["log"]("Caught error: %s", err)
			end
		end
		for _, fn in pairs(func) do
			setfenv(fn, Env)
		end

		setmetatable(Class, {
			__index = function(_, key)
				return func[key] or rawget(Class, key)
			end
		})

		Env["log"](("Finished instantiating component %s"):format(name))

		return Class
	end
}
